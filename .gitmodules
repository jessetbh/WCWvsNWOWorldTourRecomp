# Runtime stack submodules. These are jessetbh forks of the upstream projects,
# each carrying the project-local [wcw fix] set on a `wcw` branch (upstream declined
# the general fixes — see docs/upstream/). lib-patches/ remains the diff-vs-upstream
# record. Clone with: git submodule update --init --recursive

[submodule "lib/N64ModernRuntime"]
	path = lib/N64ModernRuntime
	url = https://github.com/jessetbh/N64ModernRuntime.git
	branch = wcw
[submodule "lib/RecompFrontend"]
	path = lib/RecompFrontend
	url = https://github.com/jessetbh/RecompFrontend.git
	branch = wcw
[submodule "lib/rt64"]
	path = lib/rt64
	url = https://github.com/jessetbh/rt64.git
	branch = wcw
[submodule "WCWSyms"]
	path = WCWSyms
	url = https://github.com/jessetbh/WCWSyms.git
